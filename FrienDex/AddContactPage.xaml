<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="FrienDex.AddContactPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Add Contact">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="14">

            <Label Text="Name" FontAttributes="Bold" />
            <Entry Placeholder="e.g., John Doe"
                   Text="{Binding Name}" />

            <Label Text="Room (optional)" FontAttributes="Bold" />
            <Entry Placeholder="e.g., Study Group"
                   Text="{Binding Room}" />

            <HorizontalStackLayout Spacing="12" Margin="0,20,0,0">
                <Button Text="Save"
                        Command="{Binding SaveCommand}"
                        HorizontalOptions="FillAndExpand" />
                <Button Text="Cancel"
                        Command="{Binding CancelCommand}"
                        HorizontalOptions="FillAndExpand" />
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>