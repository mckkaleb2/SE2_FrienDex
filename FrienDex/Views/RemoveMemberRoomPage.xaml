<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FrienDex.Views.RemoveMemberRoomPage"
             Title="RemoveMemberRoomPage">
    <Grid RowDefinitions="Auto, Auto, *, Auto" Padding="20" RowSpacing="15">

        <Label 
        Grid.Row="1"
        Text="Select people to remove:"
        FontAttributes="Bold" />

        <CollectionView
        Grid.Row="2"
        ItemsSource="{Binding People}"
        SelectionMode="Multiple"
        SelectionChanged="PeopleCollectionView_SelectionChanged">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="10" HeightRequest="50">
                        <Label Text="{Binding FullName}" VerticalOptions="Center" FontSize="18" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <Label Text="No available people to remove" VerticalOptions="Center" HorizontalTextAlignment="Center"/>
            </CollectionView.EmptyView>
        </CollectionView>

        <Button 
        Grid.Row="3"
        Text="Remove Members"
        Clicked="OnRemoveButtonClicked"
        HorizontalOptions="Center" 
        Margin="0,10,0,0"/>

    </Grid>
</ContentPage>