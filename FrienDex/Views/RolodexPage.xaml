        <!-- Person List -->
        <!-- This is essentially a copy of the Contact list, but for the Person object.-->
        <CollectionView Grid.Row="0"
                        ItemsSource="{Binding People}"
                        SelectionMode="Single"
                        SelectionChangedCommand="{Binding PersonSelectedCommand}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <StackLayout Padding="12" Spacing="8" Margin="0,0,0,12">
                        <Label FontSize="18" FontAttributes="Bold">
                            <Label.Text>
                                <MultiBinding StringFormat="{}{0} {1}">
                                    <Binding Path="FirstName" />
                                    <Binding Path="LastName" />
                                </MultiBinding>
                            </Label.Text>
                        </Label>
                        <!--<Label Text="{Binding Room, StringFormat='Room: {0}'}"
                               FontSize="14"
                               Opacity="0.7" />-->
                    </StackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Fixed Add Contact Button -->
        <Button Grid.Row="1"
                Text="Add Contact"
                Clicked="NavigateToCreatePage"
                Command="{Binding AddContactCommand}"
                Padding="12,16"
                CornerRadius="8"
                FontSize="16"
                FontAttributes="Bold" />
        
    </Grid>
</ContentPage>