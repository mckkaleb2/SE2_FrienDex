<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="FrienDex.RoomsPage"
    Title="Rooms">

    <Grid RowDefinitions="*,Auto" Padding="16">

        <CollectionView
            ItemsSource="{Binding Rooms}"
            SelectionMode="None">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="12" RowDefinitions="Auto,Auto">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer 
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, BindingContext.RoomSelectedCommand}"
                                CommandParameter="{Binding .}" />
                        </Grid.GestureRecognizers>

                        <Label 
                            Text="{Binding Name}" 
                            FontSize="18" 
                            FontAttributes="Bold" />

                        <Label 
                            Grid.Row="1"
                            Text="{Binding Description}" 
                            FontSize="14" 
                            Opacity="0.7" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

        <Button
            Grid.Row="1"
            Text="Add Room"
            Command="{Binding AddRoomCommand}"
            Padding="12,16"
            CornerRadius="8"
            FontSize="16"
            FontAttributes="Bold" />

    </Grid>
</ContentPage>