<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FrienDex.Views.ViewPersonPage"
             Title="ViewPerson"
             Padding="0">
    
    <Grid RowDefinitions="*,Auto" ColumnDefinitions="*">
        
        <!-- Main Scrollable Content -->
        <ScrollView Grid.Row="0" Padding="20,20,20,20">
            <VerticalStackLayout Spacing="20">
                
                <!-- Name Header -->
                <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                    <Label 
                        x:Name="NameLabel"
                        FontSize="32"
                        FontAttributes="Bold"
                        HorizontalOptions="Center"
                        HorizontalTextAlignment="Center"
                        LineBreakMode="WordWrap" />
                </VerticalStackLayout>
                
                <!-- IsFavorite Indicator -->
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                    <Label 
                        x:Name="FavoriteIndicator"
                        FontSize="20" />
                    <Label 
                        x:Name="FavoriteLabel"
                        FontSize="14"
                        VerticalOptions="Center" />
                </HorizontalStackLayout>
                
                <!-- Rooms Pills -->
                <VerticalStackLayout Spacing="8">
                    <Label 
                        Text="Rooms"
                        FontSize="16"
                        FontAttributes="Bold" />
                    <FlexLayout 
                        x:Name="RoomsPillContainer"
                        Wrap="Wrap"
                        JustifyContent="Start"
                        AlignItems="Center"
                        Margin="0,-4,0,-4" />
                </VerticalStackLayout>
                
                <!-- Divider -->
                <BoxView 
                    Color="#E0E0E0"
                    HeightRequest="1"
                    Margin="0,10,0,10" />
                
                <!-- DexEntry Section -->
                <VerticalStackLayout Spacing="8">
                    <Label 
                        Text="Details"
                        FontSize="16"
                        FontAttributes="Bold" />
                    <Border 
                        x:Name="DexEntryBorder"
                        Stroke="#E0E0E0"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 8,8,8,8"
                        Padding="12"
                        MinimumHeightRequest="100">
                        <VerticalStackLayout>
                            <Label 
                                x:Name="DexEntryContent"
                                FontSize="14"
                                LineHeight="1.4" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
                
            </VerticalStackLayout>
        </ScrollView>
        
        <!-- Edit FAB (Floating Action Button) -->
        <Button 
            Grid.Row="1"
            Text="✏️ Edit"
            Clicked="OnEditClicked"
            Margin="20"
            CornerRadius="25"
            HorizontalOptions="End"
            VerticalOptions="End"
            Padding="20,10"
            BackgroundColor="#FF6B6B"
            TextColor="White"
            FontAttributes="Bold"
            FontSize="16" />
        
    </Grid>
    
</ContentPage>