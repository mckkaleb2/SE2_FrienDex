<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FrienDex.Components.ContactBlockView"
             x:Name="Root">
    <Border
        StrokeThickness="0"
        Padding="16"
        StrokeShape="RoundRectangle 12"
        HorizontalOptions="Fill"
        VerticalOptions="Start"
        MinimumHeightRequest="60">

        <VerticalStackLayout Spacing="6">

            <!-- Contact Type -->
            <Label
                Text="{Binding ContactType, Source={x:Reference Root}}"
                FontSize="18"
                FontAttributes="Bold" />

            <!-- Contact Value -->
            <Label
                Text="{Binding ContactValue, Source={x:Reference Root}}"
                FontSize="16"
                TextColor="Gray" />

        </VerticalStackLayout>

    </Border>
</ContentView>
