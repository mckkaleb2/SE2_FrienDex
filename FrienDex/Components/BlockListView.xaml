<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:FrienDex.Components"
             xmlns:templates="clr-namespace:FrienDex.Components.Templates"
             x:Name="Root"
             x:Class="FrienDex.Components.BlockListView">
    <ContentView.Resources>
        <templates:BlockTemplateSelector x:Key="BlockTemplateSelector" />
    </ContentView.Resources>

    <CollectionView
        ItemsSource="{Binding Blocks, Source={x:Reference Root}}"
        ItemTemplate="{StaticResource BlockTemplateSelector}"
        Margin="0,8" />
</ContentView>
