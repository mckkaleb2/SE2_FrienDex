<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FrienDex.Components.DatePickerBlockView">
    <Border
        StrokeThickness="0"
        BackgroundColor="{DynamicResource CardBackgroundColor}"
        Padding="16"
        StrokeShape="RoundRectangle 12">

        <VerticalStackLayout Spacing="6">

            <Label
                Text="{Binding DateTitle, Source={x:Reference Root}}"
                FontSize="18"
                FontAttributes="Bold" />

            <Label
                Text="{Binding DateDescription, Source={x:Reference Root}}"
                FontSize="14"
                TextColor="Gray" />

            <Label
                Text="{Binding SelectedDate, Source={x:Reference Root}, StringFormat='{0:MMMM d, yyyy}'}"
                FontSize="16"
                FontAttributes="Italic" />

        </VerticalStackLayout>

    </Border>
</ContentView>
