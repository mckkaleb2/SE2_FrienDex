<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FrienDex.MainPage"
             Title="">
    <Grid RowDefinitions="*,Auto" ColumnDefinitions="*,*">
        
        <!-- Content Area -->
        <StackLayout Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" 
                     Padding="16" VerticalOptions="Start" HorizontalOptions="Center">
            <Image Source="Resources/Images/title.svg"
                       HorizontalOptions="Center" />

            <!-- Rolodex Tab Button -->
            <StackLayout Spacing="8" VerticalOptions="Center" HorizontalOptions="Center">
                <Image Source="Resources/Images/users.svg" 
           WidthRequest="56"
           HeightRequest="56"
           HorizontalOptions="Center" />
                <Label Text="Rolodex" 
           FontSize="14"
           FontAttributes="Bold"
           HorizontalTextAlignment="Center" />
                <StackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="RolodexButtonClicked" />
                </StackLayout.GestureRecognizers>
            </StackLayout>

            <!-- Rooms Tab Button -->
            <StackLayout Spacing="8" VerticalOptions="Center" HorizontalOptions="Center">
                <Image Source="Resources/Images/box.svg" 
           WidthRequest="56"
           HeightRequest="56"
           HorizontalOptions="Center" />
                <Label Text="Rooms" 
           FontSize="14"
           FontAttributes="Bold"
           HorizontalTextAlignment="Center" />
                <StackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="RoomButtonClicked" />
                </StackLayout.GestureRecognizers>
            </StackLayout>

        </StackLayout>


        <StackLayout Spacing="8" VerticalOptions="End" HorizontalOptions="Center">
            <Image Source="Resources/Images/box.svg" 
           WidthRequest="56"
           HeightRequest="56"
           HorizontalOptions="Center" />
            <Label Text="DEBUG" 
           FontSize="14"
           FontAttributes="Bold"
           HorizontalTextAlignment="Center" />
            <StackLayout.GestureRecognizers>
                <TapGestureRecognizer Tapped="DebugButtonClicked" />
            </StackLayout.GestureRecognizers>
        </StackLayout>

    </Grid>
</ContentPage>