<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FrienDex.MainPage"
             Title="">
    <Grid RowDefinitions="*,*" ColumnDefinitions="*,*">
        
        <!-- Content Area -->
        <StackLayout Grid.Row="0" Grid.ColumnSpan="2" VerticalOptions="Center">
            <Image Source="Resources/Images/title.svg"
                   WidthRequest="450"
                   ZIndex="1"
           HorizontalOptions="Center"/>
            <Label  Text="FrienDex" ZIndex="-2" FontSize="24"
                        FontAttributes="Bold" HorizontalOptions="Center" >
                <Label.Opacity>
                    <OnPlatform x:TypeArguments="x:Double" default="0.5">
                        <On Platform="Android" Value="0.0" />
                        <On Platform="WinUI" Value="1.0" />
                    </OnPlatform>
                </Label.Opacity>
            </Label>
        </StackLayout>

        <StackLayout Grid.ColumnSpan="2" Grid.Row="1">
            <!-- Rolodex Button -->
            <StackLayout VerticalOptions="Start" HorizontalOptions="Center">
                <Label  Text="Rolodex" ZIndex="-2" FontSize="24"
                        FontAttributes="Bold" HorizontalOptions="Center" >
                    <Label.Opacity>
                        <OnPlatform x:TypeArguments="x:Double" default="0.5">
                            <On Platform="Android" Value="0.0" />
                            <On Platform="WinUI" Value="1.0" />
                        </OnPlatform>
                    </Label.Opacity>
                </Label>

                    <!--<Image ZIndex="1" Source="Resources/Images/rolodex_button.svg"-->
                <Image ZIndex="1"
                       MaximumWidthRequest="360" >
                    <Image.Source>
                        <OnPlatform x:TypeArguments="ImageSource">
                            <On Platform="Android" Value="Resources/Images/rolodex_button.svg" />
                            <On Platform="WinUI" Value="Resources/Images/rolodex_button.png" />
                        </OnPlatform>
                    </Image.Source>
                </Image>

                <StackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="RolodexButtonClicked" />
                </StackLayout.GestureRecognizers>
            </StackLayout>

            <!-- Rooms Tab Button -->
            <StackLayout Padding="8" VerticalOptions="Start" HorizontalOptions="Center">
                <Label  Text="Rooms" ZIndex="-2" FontSize="24"
                        FontAttributes="Bold" HorizontalOptions="Center" >
                    <Label.Opacity>
                        <OnPlatform x:TypeArguments="x:Double" default="0.5">
                            <On Platform="Android" Value="0.0" />
                            <On Platform="WinUI" Value="1.0" />
                        </OnPlatform>
                    </Label.Opacity>
                </Label>
                <Image Source="Resources/Images/room_button.svg" 
                       MaximumWidthRequest="350" />
                <StackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="RoomButtonClicked" />
                </StackLayout.GestureRecognizers>
            </StackLayout>
        </StackLayout>

    </Grid>
     
</ContentPage>